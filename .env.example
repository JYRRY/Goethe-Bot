# Telegram Bot Token (get from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram channel that users must join before using the bot
REQUIRED_CHANNEL_ID=@JYRYGROUP

# Scraping interval in minutes
SCRAPE_INTERVAL_MINUTES=3

# Database file path
DATABASE_PATH=data/goethe_bot.db

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
